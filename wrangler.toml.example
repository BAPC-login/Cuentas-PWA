name = "cuentas-pwa-api"
main = "backend/src/index.js"
compatibility_date = "2026-07-01"

[vars]
APP_ORIGIN = "https://bapc-login.github.io"
OWNER_EMAIL = "owner@cuentas.local"
SESSION_DAYS = "3650"
CODE_TTL_MINUTES = "10"

[[d1_databases]]
binding = "DB"
database_name = "cuentas-pwa-db"
database_id = "poner-id-de-d1-aqui"
